# Project22 frontend environment variables (Vite)
# Copy to .env and fill in real values. Never commit the real .env.
# These are PUBLIC client-side keys (anon key is safe to expose); the
# Supabase service-role key and Stripe secret key live ONLY in Supabase
# Edge Function env, never in this repo.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
